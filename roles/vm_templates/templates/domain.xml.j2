{#
  libvirt domain XML for a single vPAC VM.
  Rendered by roles/vm_templates with:
    _vm      — one vm_catalog entry (name, vcpus, pinned_cpus, emulator_cpus,
               memory_gb, hugepages, preserve_mac, mac_address, nics[], disks[],
               pci_passthrough[], rt_priority, etc.)
    _profile — profile defaults merged under the catalog entry
               (cpu_mode, hugepage_size_gb, lock_memory, memballoon, watchdog,
               hpet_present, disk_cache, disk_io, disk_bus, os_type_machine, etc.)

  UUID is derived deterministically from the VM name via to_uuid with a
  fixed namespace — same VM name always produces the same UUID, so
  re-renders are idempotent without having to persist the UUID elsewhere.
#}
{%- set _vm_uuid = _vm.name | to_uuid('6ba7b810-9dad-11d1-80b4-00c04fd430c8') -%}
{%- set _hp_gb = _vm.hugepage_size_gb | default(_profile.hugepage_size_gb) | default(0) | int -%}
{#- RT discriminator: a VM opts in by setting rt_priority (per-VM) or by
    inheriting a non-zero rt_priority_default from its profile. Every
    RT-only XML element below gates on _is_rt. -#}
{%- set _rt_prio = (_vm.rt_priority | default(_profile.rt_priority_default | default(0))) | int -%}
{%- set _is_rt = _rt_prio > 0 -%}
<!-- vPAC-managed domain: {{ _vm.name }}. Re-rendered by roles/vm_templates; do not edit by hand. -->
<domain type='kvm'>
  <name>{{ _vm.name }}</name>
  <uuid>{{ _vm_uuid }}</uuid>
  <memory unit='GiB'>{{ _vm.memory_gb }}</memory>
  <currentMemory unit='GiB'>{{ _vm.memory_gb }}</currentMemory>
{% if (_vm.hugepages | default(false)) and _hp_gb > 0 %}
  <memoryBacking>
    <hugepages>
      <page size='{{ _hp_gb }}' unit='GiB'/>
    </hugepages>
{%   if _profile.lock_memory | default(false) %}
    <locked/>
{%   endif %}
{%   if _profile.nosharepages | default(false) %}
    <nosharepages/>
{%   endif %}
  </memoryBacking>
{% elif _profile.lock_memory | default(false) or _profile.nosharepages | default(false) %}
  <memoryBacking>
{%   if _profile.lock_memory | default(false) %}
    <locked/>
{%   endif %}
{%   if _profile.nosharepages | default(false) %}
    <nosharepages/>
{%   endif %}
  </memoryBacking>
{% endif %}
  <vcpu placement='static'>{{ _vm.vcpus }}</vcpu>
{% if _vm.pinned_cpus is defined and (_vm.pinned_cpus | length) > 0 %}
  <cputune>
{%   for cpu in _vm.pinned_cpus %}
    <vcpupin vcpu='{{ loop.index0 }}' cpuset='{{ cpu }}'/>
{%   endfor %}
{%   if _vm.emulator_cpus is defined and (_vm.emulator_cpus | length) > 0 %}
    <emulatorpin cpuset='{{ _vm.emulator_cpus | join(",") }}'/>
    <iothreadpin iothread='1' cpuset='{{ _vm.emulator_cpus | join(",") }}'/>
{%   endif %}
{#  RT scheduling: vCPUs run at FIFO _rt_prio (40 for VPR, 50 for SSC600 in
    the reference profiles). Emulator + iothread threads run at FIFO 1 so
    they don't preempt the vCPUs but still beat SCHED_OTHER work (chrony,
    sshd) that would otherwise starve them under host load. #}
{%   if _is_rt %}
{%     for cpu in _vm.pinned_cpus %}
    <vcpusched vcpus='{{ loop.index0 }}' scheduler='fifo' priority='{{ _rt_prio }}'/>
{%     endfor %}
    <emulatorsched scheduler='fifo' priority='1'/>
{%     if _vm.emulator_cpus is defined and (_vm.emulator_cpus | length) > 0 %}
    <iothreadsched iothreads='1' scheduler='fifo' priority='1'/>
{%     endif %}
{%   endif %}
  </cputune>
{#  Strict NUMA pinning: the kernel will only satisfy hugepage allocations
    from the named node, never silently from a remote node on multi-socket
    hosts. Reference single-socket hardware uses node 0; override per-VM
    via _vm.numa_node when relevant. #}
{%   if _is_rt %}
  <numatune>
    <memory mode='strict' nodeset='{{ _vm.numa_node | default(_profile.numa_node) | default(0) }}'/>
  </numatune>
{%   endif %}
{% endif %}
{% if _vm.emulator_cpus is defined and (_vm.emulator_cpus | length) > 0 %}
  <iothreads>1</iothreads>
{% endif %}
  <os>
    <type arch='{{ _profile.os_type_arch | default("x86_64") }}' machine='{{ _profile.os_type_machine | default("q35") }}'>hvm</type>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
{# RT features block: apic eoi=on (Intel APIC EOI optimization), kvm
   hint-dedicated=on (tells the guest its vCPUs are dedicated), poll-control=off
   (disable adaptive halt-poll which adds jitter), pv-ipi=on (paravirt IPI
   shortcut, lower latency than HW APIC). pmu off prevents the guest's
   perfmon counters from causing PMI storms on isolated cores; gated on RT,
   not on memballoon. vmport off disables the legacy VMware backdoor port
   (jitter source). #}
{% if _is_rt %}
    <apic eoi='on'/>
    <kvm>
      <hint-dedicated state='on'/>
      <poll-control state='off'/>
      <pv-ipi state='on'/>
    </kvm>
    <vmport state='off'/>
    <pmu state='off'/>
{% else %}
    <apic/>
{% endif %}
  </features>
  <cpu mode='{{ _profile.cpu_mode | default("host-passthrough") }}' check='none' migratable='on'>
    <cache mode='passthrough'/>
{# Explicit topology suppresses any in-guest hyperthread split on RT VMs
   so the guest sees N single-thread cores, matching the host-side
   isolation pattern (cores isolated whole, no thread split). Default
   sockets=1, threads=1, cores derived from vcpus. #}
{% if _is_rt %}
{%   set _topo_sockets = (_vm.cpu_topology.sockets | default(_profile.cpu_topology.sockets | default(1))) | int %}
{%   set _topo_threads = (_vm.cpu_topology.threads | default(_profile.cpu_topology.threads | default(1))) | int %}
{%   set _topo_cores = (_vm.vcpus | int // (_topo_sockets * _topo_threads)) | int %}
    <topology sockets='{{ _topo_sockets }}' cores='{{ _topo_cores }}' threads='{{ _topo_threads }}'/>
{# invtsc exposes invariant TSC to the guest — required for migratable RT
   VMs where the guest pins its clock to TSC and would otherwise reject
   migration to a host with a different-feeling TSC. #}
    <feature policy='require' name='invtsc'/>
{% endif %}
  </cpu>
  <clock offset='utc'>
    <timer name='rtc' tickpolicy='catchup'/>
    <timer name='pit' tickpolicy='delay'/>
    <timer name='hpet' present='{{ "yes" if (_profile.hpet_present | default(false)) else "no" }}'/>
{# kvmclock + tsc native: without these, an RT guest falls back to HPET
   (~3.6 µs per timer read) which dominates jitter at any meaningful read
   rate. tsc mode='native' lets the guest read the TSC directly without
   trapping into the hypervisor. #}
{% if _is_rt %}
    <timer name='kvmclock' present='yes'/>
    <timer name='tsc' present='yes' mode='native'/>
{% endif %}
  </clock>
{# Disable ACPI sleep states on RT VMs. Without this, the guest's
   suspend-to-mem path can be triggered (rare but observed during
   pacemaker stop sequences with QGA installed; suspend-instead-of-shutdown
   leaves the cluster in an inconsistent state). #}
{% if _is_rt %}
  <pm>
    <suspend-to-mem enabled='no'/>
    <suspend-to-disk enabled='no'/>
  </pm>
{% endif %}
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>restart</on_crash>
  <devices>
    <emulator>/usr/libexec/qemu-kvm</emulator>
{% for disk in _vm.disks | default([]) %}
{#   _resolve_disk_path: sources like "cephfs:/vms/foo.qcow2" become "/vms/foo.qcow2";
     "/absolute/path.qcow2" stays as-is. #}
{%   set _path = disk.source.split(":", 1)[1] if (":" in disk.source) else disk.source %}
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' cache='{{ disk.cache | default(_profile.disk_cache) | default("none") }}' io='{{ disk.io | default(_profile.disk_io) | default("native") }}'/>
      <source file='{{ _path }}'/>
      <target dev='vd{{ "abcdefgh"[loop.index0] }}' bus='{{ disk.bus | default(_profile.disk_bus) | default("virtio") }}'/>
    </disk>
{% endfor %}
{% for nic in _vm.nics | default([]) %}
    <interface type='bridge'>
      <source bridge='{{ nic.bridge }}'/>
{%   if (_vm.preserve_mac | default(false)) and _vm.mac_address is defined %}
      <mac address='{{ _vm.mac_address }}'/>
{%   endif %}
      <model type='{{ nic.model | default("virtio") }}'/>
    </interface>
{% endfor %}
{% for pci in _vm.pci_passthrough | default([]) %}
{#   PCI address like "0000:18:00.0" → 4 parts: domain:bus:slot.function #}
{%   set _parts = pci | regex_replace("[:.]", " ") | split %}
    <hostdev mode='subsystem' type='pci' managed='yes'>
      <source>
        <address domain='0x{{ _parts[0] }}' bus='0x{{ _parts[1] }}' slot='0x{{ _parts[2] }}' function='0x{{ _parts[3] }}'/>
      </source>
    </hostdev>
{% endfor %}
{% if _profile.memballoon | default(true) %}
    <memballoon model='virtio'/>
{% else %}
    <memballoon model='none'/>
{% endif %}
{#   libvirt + q35 auto-injects <watchdog model='itco' action='reset'/> if
     we don't emit anything — the ITCO watchdog is part of the PCH chipset
     emulation. Leaving it with action='reset' is what tripped past field
     deployments (false-positive watchdog reboots under load). We always emit an
     explicit <watchdog> so the action is deterministic:
       watchdog: false (default, RT profiles) → action='none' — present
         but neutered; libvirt schema requires the element to exist on
         q35, we just make it a no-op.
       watchdog: true (opt-in)                → action='reset'.
  #}
{% if _profile.watchdog | default(false) %}
    <watchdog model='itco' action='reset'/>
{% else %}
    <watchdog model='itco' action='none'/>
{% endif %}
    <serial type='pty'>
      <target type='isa-serial' port='0'>
        <model name='isa-serial'/>
      </target>
    </serial>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>
    <graphics type='vnc' port='-1' autoport='yes' listen='127.0.0.1'/>
  </devices>
</domain>
