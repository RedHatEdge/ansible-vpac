# Managed by ansible-vpac / virtualization role — do not edit by hand.
# Regenerate: ansible-playbook site.yml --tags virt-tuned
#
# Consumed by tuned's cpu-partitioning profile (and by realtime-virtual-host,
# which inherits cpu-partitioning). The profile writes kernel cmdline entries
# for isolcpus / nohz_full / rcu_nocbs from this variable when the profile
# is next applied.

isolated_cores={{ rt_tuning.isolated_cpus }}

# Move kernel-managed IRQs (NIC queues, NVMe, etc.) off the isolated cores at
# runtime. Without this, kernel-managed IRQs land on whatever CPU the kernel
# picks — including isolated ones — and steal jitter from RT VMs. Requires
# kernel support; present in stock RHEL 9 and kernel-rt.
isolate_managed_irq=Y
