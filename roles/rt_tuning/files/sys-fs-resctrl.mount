[Unit]
Description=Mount /sys/fs/resctrl for Intel CAT (Cache Allocation Technology)
Documentation=man:resctrl(7)
DefaultDependencies=no
ConditionPathExists=/sys/fs/resctrl

# Resctrl must be mounted before any consumer that calls pqos -e/-a
# (the SSC600 startup service is the documented one). intel-cmt-cat
# package (installed by virtualization role) provides pqos.

[Mount]
What=resctrl
Where=/sys/fs/resctrl
Type=resctrl
Options=defaults

[Install]
WantedBy=multi-user.target
